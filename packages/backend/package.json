{
  "name": "@explorer/backend",
  "version": "1.0.0",
  "scripts": {
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/adapters/driven/postgresql/migrate.ts",
    "db:flush": "bun --env-file=../../.env src/adapters/driven/postgresql/flush.ts",
    "db:seed": "bun --env-file=../../.env src/adapters/driven/postgresql/seed.ts",
    "db:reset": "bun run db:migrate && bun run db:flush && bun run db:seed",
    "test": "bun test --env-file=../../.env",
    "dev": "bun --env-file=../../.env --watch src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@explorer/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "logestic": "^1.2.4",
    "postgres": "^3.4.9",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10"
  }
}
