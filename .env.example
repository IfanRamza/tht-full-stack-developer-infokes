# Environment (development/production)
NODE_ENV=development

# === Database Configuration ===

# PostgreSQL (Primary)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=explorer
POSTGRES_PORT=5432
DATABASE_URL=postgres://admin:password@localhost:5432/explorer

# === Application Configuration ===

# The port where the Backend API (Elysia) will listen
PORT=3000

# === Frontend Configuration ===

# Base URL for the API, consumed by Vite (packages/frontend).
# In development, Vite's proxy rewrites /api → http://localhost:3000/api
# In production, set this to the full backend URL (e.g. https://api.yourdomain.com/api)
VITE_API_BASE_URL=/api


